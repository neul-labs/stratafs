[Desktop Entry]
Type=Application
Version=1.0
Name=AgentFS
GenericName=Agentic Filesystem
Comment=The Agentic Filesystem for AI agents
Keywords=filesystem;search;ai;agent;embedding;semantic;indexing;
Exec=agentfs-launcher
Icon=agentfs
Terminal=false
StartupNotify=true
Categories=System;FileManager;Network;Utility;
MimeType=inode/directory;

# Additional metadata
X-GNOME-UsesNotifications=true
X-Desktop-File-Install-Version=0.24

# Actions for right-click menu
Actions=start;stop;restart;status;config;web;

[Desktop Action start]
Name=Start AgentFS
Exec=agentfs-launcher start

[Desktop Action stop]
Name=Stop AgentFS
Exec=agentfs-launcher stop

[Desktop Action restart]
Name=Restart AgentFS
Exec=agentfs-launcher restart

[Desktop Action status]
Name=Show Status
Exec=agentfs-launcher status

[Desktop Action config]
Name=Show Configuration
Exec=agentfs-launcher config

[Desktop Action web]
Name=Open Web Interface
Exec=agentfs-launcher web